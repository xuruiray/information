<!DOCTYPE html>
<html lang="{{ site.language | default('zh-CN') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site.title }} · {{ labels.archive_title }}</title>
<meta name="description" content="{{ site.description }}">
<link rel="stylesheet" href="{{ asset_prefix }}assets/newspaper.css">
</head>
<body>
<div class="stage">
  <article class="sheet">
    <button class="peel" type="button" title="回到顶部" aria-label="回到顶部"></button>
    <header class="masthead">
      <div class="corners">
        <span>ARCHIVE</span>
        <span>{{ site.edition_label }}</span>
      </div>
      <h1 class="title">{% if lang == 'en' %}{{ site.title }} Archive{% else %}往期{{ site.title }}{% endif %}</h1>
      <div class="subtitle">{{ site.subtitle }}</div>
    </header>

    <nav class="language-switch" aria-label="Language">
      <a href="{% if lang == 'en' %}{{ current_href }}{% else %}{{ alternate_href }}{% endif %}"{% if lang == 'en' %} aria-current="page"{% endif %}>{{ labels.language_en }}</a>
      <a href="{% if lang == 'zh' %}{{ current_href }}{% else %}{{ alternate_href }}{% endif %}"{% if lang == 'zh' %} aria-current="page"{% endif %}>{{ labels.language_zh }}</a>
    </nav>

    <div class="archive-list">
      {% for item in items %}
      <a class="art" href="{{ item.path }}">
        <span class="at">{{ item.date }} {{ site.title }}</span>
        {% if item.headline %}
        <p class="as">{% if lang == 'en' %}{{ item.headline.title_en or item.headline.title }}{% else %}{{ item.headline.title }}{% endif %}</p>
        {% endif %}
        <span class="by">{{ item.profile_id }} · {{ item.raw_count }} articles</span>
      </a>
      {% else %}
      <p class="empty">{{ labels.empty_archive }}</p>
      {% endfor %}
    </div>

    <footer class="colophon">
      <a href="{{ index_href }}">← {{ labels.back_today }}</a>
      <span>{{ generated_at }}</span>
    </footer>
  </article>
</div>
<script>
(function(){
  document.querySelectorAll('.peel').forEach(function(peel){
    peel.addEventListener('click', function(){ window.scrollTo({top: 0, behavior: 'smooth'}); });
  });
})();
</script>
</body>
</html>
