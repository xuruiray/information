<!DOCTYPE html>
<html lang="{{ site.language | default('zh-CN') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ issue.title }}</title>
<meta name="description" content="{{ site.description }}">
<link rel="stylesheet" href="{{ asset_prefix }}assets/newspaper.css">
</head>
<body>
<div class="stage">
  <article class="sheet front overview" id="overview">
    <button class="peel" type="button" title="回到顶部" aria-label="回到顶部"></button>
    <header class="masthead">
      <div class="corners">
        <span>{% if lang == 'en' %}Issue {{ issue.date.strftime('%Y%m%d') }}{% else %}第 {{ issue.date.strftime('%Y%m%d') }} 期{% endif %}</span>
        <span>{{ issue.edition_label }}</span>
      </div>
      <h1 class="title">{{ issue.site_title }}</h1>
      <div class="subtitle">{{ issue.site_subtitle }}</div>
      <div class="dateline"><span>{{ dateline }}</span></div>
    </header>

    <nav class="language-switch" aria-label="Language">
      <a href="{% if lang == 'en' %}{{ current_href }}{% else %}{{ alternate_href }}{% endif %}"{% if lang == 'en' %} aria-current="page"{% endif %}>{{ labels.language_en }}</a>
      <a href="{% if lang == 'zh' %}{{ current_href }}{% else %}{{ alternate_href }}{% endif %}"{% if lang == 'zh' %} aria-current="page"{% endif %}>{{ labels.language_zh }}</a>
    </nav>

    {% if issue.warnings %}
    <aside class="notice">
      {% for warning in issue.warnings %}
      <p>{{ warning }}</p>
      {% endfor %}
    </aside>
    {% endif %}

    <section class="briefing-panel issue-briefing" aria-label="{{ issue.briefing_title }}">
      <div class="lead-label">{{ issue.briefing_title }}</div>
      <p>{{ issue.briefing_summary }}</p>
      {% if issue.headline %}
      <a class="headline-link" href="{{ issue.headline.url }}" target="_blank" rel="noopener">
        {{ labels.headline }}: {{ issue.headline.title }}
      </a>
      {% endif %}
    </section>

    <nav class="edition-nav" aria-label="{{ labels.latest_editions }}">
      <span>{{ labels.latest_editions }}</span>
      {% for link in section_links %}
      <a href="{{ link.href }}">{{ link.section.display_title }}</a>
      {% endfor %}
    </nav>

    <section class="edition-grid" aria-label="{{ labels.section_pages }}">
      {% for link in section_links %}
      {% set section = link.section %}
      <a class="edition-card" href="{{ link.href }}">
        <span class="edition-no">{{ section.icon }}</span>
        <span class="edition-title">{{ section.title }}</span>
        <span class="edition-summary">{{ section.briefing_summary }}</span>
        <span class="edition-subheads">
          {% for subsection in section.subsections %}
          <span>{{ subsection.title }} · {{ subsection.articles | length }}</span>
          {% endfor %}
        </span>
      </a>
      {% endfor %}
    </section>

    <section class="overview-rail" aria-label="{{ labels.overview_rail }}">
      {% for section in issue.sections %}
      <div class="overview-section">
        <h2>{{ section.display_title }}</h2>
        <p>{{ section.briefing_summary }}</p>
        <ul>
          {% for article in section.articles[:3] %}
          <li><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </section>

    <footer class="colophon">
      <span>{{ labels.overview_footer }}</span>
      <a href="{{ archive_href }}">{{ labels.archive }} →</a>
    </footer>
  </article>
</div>

<script>
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('.peel').forEach(function(peel){
    peel.addEventListener('click', function(){
      window.scrollTo({top: 0, behavior: reduce ? 'auto' : 'smooth'});
    });
  });
})();
</script>
</body>
</html>
