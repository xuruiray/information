<!DOCTYPE html>
<html lang="{{ site.language | default('zh-CN') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ issue.title }}</title>
<meta name="description" content="{{ site.description }}">
<link rel="stylesheet" href="{{ asset_prefix }}assets/newspaper.css">
</head>
<body>
<div class="stage">
  {% for section in issue.sections %}
  <article class="sheet{% if loop.first %} front{% endif %}" id="page-{{ loop.index }}">
    <button class="peel" type="button" title="回到顶部" aria-label="回到顶部"></button>

    {% if loop.first %}
    <header class="masthead">
      <div class="corners">
        <span>第 {{ issue.date.strftime('%Y%m%d') }} 期</span>
        <span>{{ issue.edition_label }}</span>
      </div>
      <h1 class="title">{{ issue.site_title }}</h1>
      <div class="subtitle">{{ issue.site_subtitle }}</div>
      <div class="dateline"><span>{{ dateline }}</span></div>
    </header>
    {% endif %}

    {% if issue.warnings and loop.first %}
    <aside class="notice">
      {% for warning in issue.warnings %}
      <p>{{ warning }}</p>
      {% endfor %}
    </aside>
    {% endif %}

    <header class="pagehead category-head">
      <h2>{{ section.display_title }}</h2>
      <span class="ed">第 {{ loop.index }} 版 / 共 {{ issue.sections | length }} 版</span>
    </header>

    {% if loop.first %}
    <section class="briefing-panel issue-briefing" aria-label="{{ issue.briefing_title }}">
      <div class="lead-label">{{ issue.briefing_title }}</div>
      <p>{{ issue.briefing_summary }}</p>
      {% if issue.headline %}
      <a class="headline-link" href="{{ issue.headline.url }}" target="_blank" rel="noopener">
        今日重点：{{ issue.headline.title }}
      </a>
      {% endif %}
    </section>

    <nav class="edition-nav" aria-label="本期三版">
      <span>本期三版</span>
      {% for nav_section in issue.sections %}
      <a href="#page-{{ loop.index }}">{{ nav_section.display_title }}</a>
      {% endfor %}
    </nav>
    {% endif %}

    <section class="briefing-panel category-briefing" aria-label="{{ section.briefing_title }}">
      <div class="lead-label">{{ section.briefing_title }}</div>
      <p>{{ section.briefing_summary }}</p>
    </section>

    {% if section.articles %}
    <div class="columns">
      {% for article in section.articles %}
      <a class="art" href="{{ article.url }}" target="_blank" rel="noopener">
        <span class="at">{{ article.title }}</span>
        <span class="by">{{ article.source }}</span>
        <p class="as">{{ article.summary }}</p>
        <span class="more">阅读全文 →</span>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p class="empty">本版暂无入选文章。你可以在 profile 中调整关键词、数据源或栏目权重。</p>
    {% endif %}

    <footer class="colophon">
      {% if loop.first %}
      <span>第 {{ loop.index }} 版 · {{ section.title }}</span>
      <a href="#page-{{ loop.index + 1 }}">下一版 →</a>
      {% elif loop.last %}
      <a href="#page-{{ loop.index - 1 }}">← 上一版</a>
      <a href="{{ archive_href }}">往期 →</a>
      {% else %}
      <a href="#page-{{ loop.index - 1 }}">← 上一版</a>
      <a href="#page-{{ loop.index + 1 }}">下一版 →</a>
      {% endif %}
    </footer>
  </article>
  {% endfor %}
</div>

<script>
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var fine = window.matchMedia && window.matchMedia('(pointer: fine)').matches;
  document.querySelectorAll('.sheet').forEach(function(sheet){
    var peel = sheet.querySelector('.peel');
    if (peel) {
      peel.addEventListener('click', function(){
        window.scrollTo({top: 0, behavior: reduce ? 'auto' : 'smooth'});
      });
    }
    if (reduce || !fine) return;
    sheet.addEventListener('mousemove', function(event){
      var rect = sheet.getBoundingClientRect();
      var cx = (event.clientX - (rect.left + rect.width / 2)) / rect.width;
      var cy = (event.clientY - (rect.top + rect.height / 2)) / rect.height;
      sheet.style.transform = 'rotateY(' + (cx * 2.2).toFixed(2) + 'deg) rotateX(' + (-cy * 1.8).toFixed(2) + 'deg)';
    });
    sheet.addEventListener('mouseleave', function(){
      sheet.style.transform = 'rotateY(0) rotateX(0)';
    });
  });
})();
</script>
</body>
</html>
